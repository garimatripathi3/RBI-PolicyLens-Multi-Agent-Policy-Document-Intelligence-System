# Copy to .env and fill in. Everything is optional for the offline scaffold.

# LLM (Research Agent synthesis)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# spaCy model for the Extraction Agent
SPACY_MODEL=en_core_web_sm

# Retrieval
TOP_K_BM25=20
TOP_K_DENSE=20
TOP_K_FINAL=5
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# QA thresholds
LOW_CONFIDENCE_THRESHOLD=0.35
MEDIUM_CONFIDENCE_THRESHOLD=0.6

# Observability (Langfuse) - leave blank to disable
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Data
POLICIES_DIR=data/policies
